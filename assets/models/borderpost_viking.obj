# S4WN Border Post — Viking (Dark brown timber + navy blue pennant)
# Placed by Pioneer settlers at territorial boundaries
mtllib borderpost_viking.mtl
o borderpost
# Base of post (wider)
v -0.1200 0.0000 -0.1200
v 0.1200 0.0000 -0.1200
v 0.1200 0.0000 0.1200
v -0.1200 0.0000 0.1200
# Top of post (narrower, tapered)
v -0.0800 1.8000 -0.0800
v 0.0800 1.8000 -0.0800
v 0.0800 1.8000 0.0800
v -0.0800 1.8000 0.0800
# Pennant flag — triangle extending +X from top
v 0.0800 1.8000 -0.0800
v 0.5500 1.4000 -0.0800
v 0.0800 1.0000 -0.0800
v 0.0800 1.8000 0.0800
v 0.5500 1.4000 0.0800
v 0.0800 1.0000 0.0800
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vn 0.0000 0.0000 -1.0000
vn 1.0000 0.0000 0.0000
vn 0.0000 0.0000 1.0000
vn -1.0000 0.0000 0.0000
vn 0.0000 1.0000 0.0000
vn 0.0000 -1.0000 0.0000
usemtl post
# Post sides (8 faces, 4 sides, 2 triangles each)
# Front face (-Z)
f 1/1/1 5/2/1 6/3/1 2/4/1
# Right face (+X)
f 2/5/2 6/6/2 7/7/2 3/8/2
# Back face (+Z)
f 3/9/3 7/10/3 8/11/3 4/12/3
# Left face (-X)
f 4/13/4 8/14/4 5/15/4 1/16/4
# Top cap
f 5/17/5 8/18/5 7/19/5 6/20/5
# Bottom cap
f 1/21/6 2/22/6 3/23/6 4/24/6
usemtl flag
# Pennant front face (-Z)
f 6/1/1 9/2/1 11/3/1
# Pennant back face (+Z)
f 7/5/3 12/6/3 13/7/3 10/8/3
