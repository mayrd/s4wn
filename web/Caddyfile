# S4WN Web Server Configuration
# Serves the game engine and static assets

:80 {
    root * /usr/share/caddy
    file_server

    # WASM requires proper MIME type
    header *.wasm Content-Type application/wasm

    # Enable compression for WASM (textual formats compress well)
    encode gzip zstd

    # Security headers
    header Cross-Origin-Opener-Policy same-origin
    header *.html Cross-Origin-Embedder-Policy require-corp
    header *.js Cross-Origin-Embedder-Policy require-corp
    header *.wasm Cross-Origin-Embedder-Policy require-corp
}
